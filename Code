<!DOCTYPE html>
<html lang="th">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>NITIRAT Green Heart 2569</title>
<link href="https://fonts.googleapis.com/css2?family=Kanit:wght@300;400;500;600;700;800;900&family=Prompt:wght@300;400;500;600;700&family=Fredoka:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
:root {
  --green-dark: #1a5c2a;
  --green-mid: #2d8a4e;
  --green-light: #4caf50;
  --green-pale: #a8e6a3;
  --green-pastel: #d4f5d0;
  --cream: #fdf6e3;
  --brown: #8b6914;
  --yellow: #ffd700;
  --orange: #ff8c00;
  --white: #ffffff;
  --text-dark: #1a3a1a;
  --text-mid: #2d5a2d;
}

* { margin: 0; padding: 0; box-sizing: border-box; }

html { scroll-behavior: smooth; }

body {
  font-family: 'Prompt', 'Kanit', sans-serif;
  background: var(--cream);
  color: var(--text-dark);
  overflow-x: hidden;
}

/* ===== NAVIGATION ===== */
.nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 1000;
  background: rgba(26, 92, 42, 0.95);
  backdrop-filter: blur(12px);
  padding: 12px 0;
  transition: all 0.3s;
}

.nav-inner {
  max-width: 1200px;
  margin: 0 auto;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 24px;
}

.nav-logo {
  font-family: 'Fredoka', sans-serif;
  font-size: 1.4rem;
  font-weight: 700;
  color: var(--green-pale);
  letter-spacing: 1px;
}

.nav-logo span { color: var(--yellow); }

.nav-links {
  display: flex;
  gap: 8px;
}

.nav-links a {
  color: var(--green-pastel);
  text-decoration: none;
  font-size: 0.85rem;
  font-weight: 500;
  padding: 6px 14px;
  border-radius: 20px;
  transition: all 0.3s;
}

.nav-links a:hover {
  background: rgba(255,255,255,0.15);
  color: var(--white);
}

/* ===== HERO ===== */
.hero {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
  background: linear-gradient(170deg, #0d3b1a 0%, #1a5c2a 30%, #2d8a4e 60%, #4caf50 100%);
}

.hero::before {
  content: '';
  position: absolute;
  inset: 0;
  background:
    radial-gradient(circle at 20% 80%, rgba(76,175,80,0.4) 0%, transparent 50%),
    radial-gradient(circle at 80% 20%, rgba(255,215,0,0.15) 0%, transparent 40%),
    radial-gradient(circle at 50% 50%, rgba(168,230,163,0.1) 0%, transparent 60%);
  z-index: 1;
}

.hero-content {
  position: relative;
  z-index: 2;
  text-align: center;
  padding: 120px 24px 60px;
  max-width: 800px;
}

.hero-badge {
  display: inline-block;
  background: rgba(255,255,255,0.15);
  border: 1px solid rgba(255,255,255,0.3);
  padding: 8px 24px;
  border-radius: 30px;
  color: var(--green-pale);
  font-size: 0.85rem;
  font-weight: 500;
  margin-bottom: 28px;
  letter-spacing: 2px;
  text-transform: uppercase;
  animation: fadeDown 0.8s ease-out;
}

.hero-title {
  font-family: 'Fredoka', sans-serif;
  font-size: clamp(3rem, 8vw, 6rem);
  font-weight: 700;
  color: var(--white);
  line-height: 1.1;
  margin-bottom: 8px;
  animation: fadeUp 0.8s ease-out 0.2s both;
  text-shadow: 0 4px 30px rgba(0,0,0,0.3);
}

.hero-title .green { color: var(--green-pale); }
.hero-title .heart { color: #ff6b6b; }

.hero-subtitle {
  font-family: 'Fredoka', sans-serif;
  font-size: clamp(1.8rem, 4vw, 3rem);
  color: var(--yellow);
  font-weight: 600;
  margin-bottom: 20px;
  animation: fadeUp 0.8s ease-out 0.35s both;
}

.hero-date {
  font-size: 1.3rem;
  color: rgba(255,255,255,0.9);
  font-weight: 400;
  margin-bottom: 36px;
  animation: fadeUp 0.8s ease-out 0.5s both;
}

.hero-date strong {
  color: var(--yellow);
  font-weight: 700;
  font-size: 1.5rem;
}

.hero-cta {
  display: inline-flex;
  gap: 16px;
  flex-wrap: wrap;
  justify-content: center;
  animation: fadeUp 0.8s ease-out 0.65s both;
}

.btn {
  display: inline-block;
  padding: 14px 36px;
  border-radius: 50px;
  font-family: 'Prompt', sans-serif;
  font-size: 1rem;
  font-weight: 600;
  text-decoration: none;
  cursor: pointer;
  border: none;
  transition: all 0.35s cubic-bezier(0.4, 0, 0.2, 1);
}

.btn-primary {
  background: var(--yellow);
  color: var(--green-dark);
  box-shadow: 0 4px 20px rgba(255,215,0,0.4);
}

.btn-primary:hover {
  transform: translateY(-3px);
  box-shadow: 0 8px 30px rgba(255,215,0,0.5);
}

.btn-outline {
  background: transparent;
  color: var(--white);
  border: 2px solid rgba(255,255,255,0.5);
}

.btn-outline:hover {
  background: rgba(255,255,255,0.1);
  border-color: var(--white);
  transform: translateY(-3px);
}

/* Floating leaves */
.leaf {
  position: absolute;
  font-size: 2rem;
  opacity: 0.3;
  animation: floatLeaf 15s infinite linear;
  z-index: 1;
}

.leaf:nth-child(1) { left: 10%; animation-delay: 0s; animation-duration: 18s; }
.leaf:nth-child(2) { left: 25%; animation-delay: 3s; animation-duration: 22s; }
.leaf:nth-child(3) { left: 45%; animation-delay: 6s; animation-duration: 16s; }
.leaf:nth-child(4) { left: 65%; animation-delay: 2s; animation-duration: 20s; }
.leaf:nth-child(5) { left: 80%; animation-delay: 5s; animation-duration: 17s; }
.leaf:nth-child(6) { left: 90%; animation-delay: 8s; animation-duration: 19s; }

@keyframes floatLeaf {
  0% { transform: translateY(-100vh) rotate(0deg); opacity: 0; }
  10% { opacity: 0.3; }
  90% { opacity: 0.3; }
  100% { transform: translateY(100vh) rotate(720deg); opacity: 0; }
}

@keyframes fadeUp {
  from { opacity: 0; transform: translateY(30px); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes fadeDown {
  from { opacity: 0; transform: translateY(-20px); }
  to { opacity: 1; transform: translateY(0); }
}

/* ===== SECTION COMMON ===== */
.section {
  padding: 80px 24px;
  max-width: 1100px;
  margin: 0 auto;
}

.section-label {
  display: inline-block;
  background: var(--green-dark);
  color: var(--green-pale);
  padding: 6px 18px;
  border-radius: 20px;
  font-size: 0.8rem;
  font-weight: 600;
  letter-spacing: 2px;
  text-transform: uppercase;
  margin-bottom: 12px;
}

.section-title {
  font-family: 'Fredoka', sans-serif;
  font-size: clamp(2rem, 5vw, 3rem);
  color: var(--green-dark);
  font-weight: 700;
  margin-bottom: 16px;
}

.section-desc {
  font-size: 1.05rem;
  color: var(--text-mid);
  max-width: 650px;
  line-height: 1.7;
  margin-bottom: 40px;
}

/* ===== ABOUT ===== */
.about-section {
  background: var(--white);
  border-bottom: 1px solid rgba(0,0,0,0.05);
}

.about-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
  gap: 24px;
}

.about-card {
  background: var(--cream);
  border-radius: 20px;
  padding: 32px 28px;
  text-align: center;
  border: 2px solid transparent;
  transition: all 0.35s;
}

.about-card:hover {
  border-color: var(--green-light);
  transform: translateY(-4px);
  box-shadow: 0 12px 30px rgba(76,175,80,0.1);
}

.about-icon {
  width: 64px;
  height: 64px;
  background: linear-gradient(135deg, var(--green-light), var(--green-dark));
  border-radius: 16px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.8rem;
  margin: 0 auto 16px;
}

.about-card h3 {
  font-family: 'Kanit', sans-serif;
  font-size: 1.15rem;
  font-weight: 600;
  color: var(--green-dark);
  margin-bottom: 8px;
}

.about-card p {
  font-size: 0.9rem;
  color: var(--text-mid);
  line-height: 1.6;
}

/* ===== SCHEDULE ===== */
.schedule-section {
  background: linear-gradient(180deg, var(--cream) 0%, var(--green-pastel) 100%);
}

.schedule-tabs {
  display: flex;
  gap: 12px;
  margin-bottom: 36px;
}

.schedule-tab {
  padding: 10px 28px;
  border-radius: 30px;
  font-family: 'Prompt', sans-serif;
  font-size: 0.95rem;
  font-weight: 600;
  cursor: pointer;
  border: 2px solid var(--green-mid);
  background: transparent;
  color: var(--green-mid);
  transition: all 0.3s;
}

.schedule-tab.active {
  background: var(--green-mid);
  color: var(--white);
}

.schedule-tab:hover:not(.active) {
  background: rgba(45,138,78,0.1);
}

.timeline {
  position: relative;
  padding-left: 40px;
}

.timeline::before {
  content: '';
  position: absolute;
  left: 15px;
  top: 0;
  bottom: 0;
  width: 3px;
  background: linear-gradient(to bottom, var(--green-light), var(--green-dark));
  border-radius: 2px;
}

.timeline-item {
  position: relative;
  margin-bottom: 28px;
  padding: 20px 24px;
  background: var(--white);
  border-radius: 16px;
  box-shadow: 0 2px 12px rgba(0,0,0,0.06);
  transition: all 0.3s;
}

.timeline-item:hover {
  transform: translateX(6px);
  box-shadow: 0 4px 20px rgba(0,0,0,0.1);
}

.timeline-item::before {
  content: '';
  position: absolute;
  left: -33px;
  top: 24px;
  width: 14px;
  height: 14px;
  background: var(--green-light);
  border: 3px solid var(--white);
  border-radius: 50%;
  box-shadow: 0 0 0 3px var(--green-light);
}

.timeline-time {
  font-family: 'Fredoka', sans-serif;
  font-size: 1.1rem;
  font-weight: 600;
  color: var(--green-dark);
  margin-bottom: 4px;
}

.timeline-title {
  font-size: 1rem;
  font-weight: 500;
  color: var(--text-dark);
}

.timeline-desc {
  font-size: 0.85rem;
  color: var(--text-mid);
  margin-top: 4px;
}

.hidden { display: none; }

/* ===== DRESS CODE ===== */
.dresscode-section {
  background: var(--white);
}

.dresscode-banner {
  background: linear-gradient(135deg, var(--green-dark), var(--green-mid));
  border-radius: 24px;
  padding: 48px 40px;
  color: var(--white);
  text-align: center;
  position: relative;
  overflow: hidden;
  margin-bottom: 32px;
}

.dresscode-banner::before {
  content: '';
  position: absolute;
  inset: 0;
  background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.05'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
}

.dresscode-banner h3 {
  font-family: 'Fredoka', sans-serif;
  font-size: 2rem;
  margin-bottom: 12px;
  position: relative;
}

.dresscode-banner p {
  font-size: 1.05rem;
  opacity: 0.9;
  max-width: 550px;
  margin: 0 auto;
  line-height: 1.7;
  position: relative;
}

.dresscode-tips {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
  gap: 20px;
}

.tip-card {
  background: var(--green-pastel);
  border-radius: 16px;
  padding: 24px;
  text-align: center;
}

.tip-icon { font-size: 2.5rem; margin-bottom: 12px; }

.tip-card h4 {
  font-size: 1rem;
  font-weight: 600;
  color: var(--green-dark);
  margin-bottom: 6px;
}

.tip-card p {
  font-size: 0.85rem;
  color: var(--text-mid);
  line-height: 1.5;
}

/* ===== MINI GAME ===== */
.game-section {
  background: linear-gradient(180deg, var(--green-pastel) 0%, var(--cream) 100%);
}

.game-container {
  background: var(--white);
  border-radius: 24px;
  padding: 40px;
  box-shadow: 0 4px 20px rgba(0,0,0,0.08);
  text-align: center;
  max-width: 700px;
  margin: 0 auto;
}

.game-score-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 28px;
  padding: 12px 20px;
  background: var(--cream);
  border-radius: 12px;
}

.game-score-bar span {
  font-weight: 600;
  color: var(--green-dark);
}

.game-score-bar .score-value {
  font-family: 'Fredoka', sans-serif;
  font-size: 1.5rem;
  color: var(--green-light);
}

.game-question {
  font-size: 1.2rem;
  font-weight: 600;
  color: var(--text-dark);
  margin-bottom: 12px;
}

.game-item {
  font-size: 3.5rem;
  margin: 16px 0 24px;
  animation: bounceIn 0.5s ease-out;
}

@keyframes bounceIn {
  0% { transform: scale(0.3); opacity: 0; }
  50% { transform: scale(1.1); }
  100% { transform: scale(1); opacity: 1; }
}

.game-item-name {
  font-size: 1.1rem;
  color: var(--text-mid);
  margin-bottom: 24px;
  font-weight: 500;
}

.bin-options {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12px;
  max-width: 500px;
  margin: 0 auto;
}

.bin-btn {
  padding: 16px;
  border-radius: 16px;
  border: 3px solid transparent;
  cursor: pointer;
  font-family: 'Prompt', sans-serif;
  font-size: 0.9rem;
  font-weight: 600;
  transition: all 0.3s;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6px;
}

.bin-btn .bin-emoji { font-size: 2rem; }

.bin-btn.blue { background: #e3f2fd; color: #1565c0; border-color: #bbdefb; }
.bin-btn.blue:hover { border-color: #1565c0; transform: scale(1.04); }
.bin-btn.green { background: #e8f5e9; color: #2e7d32; border-color: #c8e6c9; }
.bin-btn.green:hover { border-color: #2e7d32; transform: scale(1.04); }
.bin-btn.yellow { background: #fff8e1; color: #f57f17; border-color: #fff9c4; }
.bin-btn.yellow:hover { border-color: #f57f17; transform: scale(1.04); }
.bin-btn.red { background: #fce4ec; color: #c62828; border-color: #f8bbd0; }
.bin-btn.red:hover { border-color: #c62828; transform: scale(1.04); }

.bin-btn.correct {
  animation: correctPulse 0.5s;
  border-color: #4caf50 !important;
  background: #c8e6c9 !important;
}

.bin-btn.wrong {
  animation: shake 0.4s;
  border-color: #f44336 !important;
  background: #ffcdd2 !important;
}

@keyframes correctPulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.08); }
}

@keyframes shake {
  0%, 100% { transform: translateX(0); }
  25% { transform: translateX(-8px); }
  75% { transform: translateX(8px); }
}

.game-feedback {
  margin-top: 16px;
  padding: 12px 20px;
  border-radius: 12px;
  font-weight: 600;
  font-size: 0.95rem;
  min-height: 48px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.game-feedback.correct { background: #e8f5e9; color: #2e7d32; }
.game-feedback.wrong { background: #fce4ec; color: #c62828; }

.game-progress {
  margin-top: 20px;
  display: flex;
  justify-content: center;
  gap: 6px;
}

.progress-dot {
  width: 10px;
  height: 10px;
  border-radius: 50%;
  background: #e0e0e0;
  transition: all 0.3s;
}

.progress-dot.correct { background: var(--green-light); }
.progress-dot.wrong { background: #ef5350; }
.progress-dot.current { background: var(--yellow); transform: scale(1.3); }

.game-result {
  text-align: center;
  padding: 20px;
}

.game-result h3 {
  font-family: 'Fredoka', sans-serif;
  font-size: 2rem;
  color: var(--green-dark);
  margin-bottom: 12px;
}

.game-result .big-score {
  font-family: 'Fredoka', sans-serif;
  font-size: 4rem;
  color: var(--green-light);
  margin: 16px 0;
}

.game-result p {
  font-size: 1rem;
  color: var(--text-mid);
  margin-bottom: 24px;
}

/* ===== PHOTOBOOTH ===== */
.photobooth-section {
  background: var(--white);
}

.photobooth-container {
  max-width: 600px;
  margin: 0 auto;
  text-align: center;
}

.frame-selector {
  display: flex;
  gap: 12px;
  justify-content: center;
  margin-bottom: 28px;
  flex-wrap: wrap;
}

.frame-option {
  width: 80px;
  height: 80px;
  border-radius: 12px;
  border: 3px solid #e0e0e0;
  cursor: pointer;
  overflow: hidden;
  transition: all 0.3s;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 0.7rem;
  font-weight: 600;
  text-align: center;
  padding: 4px;
}

.frame-option.active {
  border-color: var(--green-light);
  box-shadow: 0 0 0 3px rgba(76,175,80,0.3);
  transform: scale(1.08);
}

.frame-option:hover { border-color: var(--green-mid); }

.canvas-wrapper {
  position: relative;
  margin: 0 auto 24px;
  border-radius: 16px;
  overflow: hidden;
  box-shadow: 0 4px 24px rgba(0,0,0,0.12);
  background: #f5f5f5;
  max-width: 480px;
}

.canvas-wrapper canvas {
  display: block;
  width: 100%;
  height: auto;
}

.photo-controls {
  display: flex;
  gap: 12px;
  justify-content: center;
  flex-wrap: wrap;
}

.photo-controls .btn {
  font-size: 0.9rem;
  padding: 12px 28px;
}

.upload-label {
  display: inline-block;
  padding: 12px 28px;
  border-radius: 50px;
  font-family: 'Prompt', sans-serif;
  font-size: 0.9rem;
  font-weight: 600;
  cursor: pointer;
  background: var(--green-mid);
  color: var(--white);
  transition: all 0.35s;
}

.upload-label:hover {
  background: var(--green-dark);
  transform: translateY(-2px);
}

#photoUpload { display: none; }

/* ===== FOOTER ===== */
.footer {
  background: var(--green-dark);
  color: rgba(255,255,255,0.7);
  text-align: center;
  padding: 40px 24px;
}

.footer-logo {
  font-family: 'Fredoka', sans-serif;
  font-size: 1.6rem;
  font-weight: 700;
  color: var(--green-pale);
  margin-bottom: 8px;
}

.footer-logo span { color: var(--yellow); }

.footer p {
  font-size: 0.85rem;
  margin-bottom: 4px;
}

.footer-heart { color: #ff6b6b; }

/* ===== RESPONSIVE ===== */
@media (max-width: 768px) {
  .nav-links { display: none; }
  .section { padding: 60px 16px; }
  .game-container { padding: 24px 16px; }
  .bin-options { grid-template-columns: repeat(2, 1fr); gap: 8px; }
  .dresscode-banner { padding: 32px 20px; }
  .timeline { padding-left: 32px; }
}

/* ===== SCROLL REVEAL ===== */
.reveal {
  opacity: 0;
  transform: translateY(30px);
  transition: all 0.7s cubic-bezier(0.4, 0, 0.2, 1);
}

.reveal.visible {
  opacity: 1;
  transform: translateY(0);
}
</style>
</head>
