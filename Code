</nav>

<!-- HERO -->
<section class="hero">
  <div class="leaf">🍃</div>
  <div class="leaf">🌿</div>
  <div class="leaf">🍀</div>
  <div class="leaf">🌱</div>
  <div class="leaf">🍃</div>
  <div class="leaf">🌿</div>
  <div class="hero-content">
    <div class="hero-badge">HR NITIRAT presents</div>
    <h1 class="hero-title">NITIRAT<br><span class="green">Green</span> <span class="heart">Heart</span></h1>
    <p class="hero-subtitle">เขียวรักษ์โลก 💚</p>
