<nav class="nav">
  <div class="nav-inner">
    <div class="nav-logo">NITIRAT <span>Green Heart</span></div>
    <div class="nav-links">
      <a href="#about">เกี่ยวกับงาน</a>
      <a href="#schedule">กำหนดการ</a>
      <a href="#dresscode">Dress Code</a>
      <a href="#game">Mini Game</a>
