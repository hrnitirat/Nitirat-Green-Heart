<script>
// ===== SCHEDULE TABS =====
function switchTab(tab) {
  document.querySelectorAll('.schedule-tab').forEach(t => t.classList.remove('active'));
  document.getElementById('morning-timeline').classList.add('hidden');
  document.getElementById('evening-timeline').classList.add('hidden');
  
  if (tab === 'morning') {
    document.getElementById('morning-timeline').classList.remove('hidden');
    document.querySelectorAll('.schedule-tab')[0].classList.add('active');
  } else {
    document.getElementById('evening-timeline').classList.remove('hidden');
    document.querySelectorAll('.schedule-tab')[1].classList.add('active');
  }
}

// ===== SCROLL REVEAL =====
const observer = new IntersectionObserver((entries) => {
  entries.forEach(entry => {
    if (entry.isIntersecting) {
      entry.target.classList.add('visible');
    }
  });
}, { threshold: 0.1 });

document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

// ===== MINI GAME: WASTE SORTING =====
const wasteItems = [
  { name: 'ขวดน้ำพลาสติก', emoji: '🧴', bin: 'recycle', fact: 'ขวดพลาสติก 1 ใบ ใช้เวลาย่อยสลาย 450 ปี!' },
  { name: 'เปลือกกล้วย', emoji: '🍌', bin: 'organic', fact: 'เศษอาหารสามารถทำปุ๋ยหมักได้ภายใน 2-6 สัปดาห์' },
  { name: 'กระดาษ A4', emoji: '📄', bin: 'recycle', fact: 'กระดาษ 1 ตัน รีไซเคิลช่วยรักษาต้นไม้ได้ 17 ต้น' },
  { name: 'ถ่านไฟฉาย', emoji: '🔋', bin: 'hazardous', fact: 'ถ่านไฟฉายมีสารปรอทและตะกั่วที่เป็นอันตราย' },
  { name: 'กล่องนม', emoji: '🥛', bin: 'recycle', fact: 'กล่องนม UHT สามารถรีไซเคิลเป็นหลังคาบ้านได้' },
  { name: 'เศษอาหาร', emoji: '🍚', bin: 'organic', fact: 'ไทยสร้างขยะอาหารกว่า 17 ล้านตันต่อปี' },
  { name: 'กระป๋องอลูมิเนียม', emoji: '🥫', bin: 'recycle', fact: 'อลูมิเนียมรีไซเคิลได้ไม่จำกัดครั้ง!' },
  { name: 'หลอดไฟ', emoji: '💡', bin: 'hazardous', fact: 'หลอดไฟมีสารปรอท ต้องทิ้งในถังขยะอันตราย' },
  { name: 'ถุงพลาสติก', emoji: '🛍️', bin: 'general', fact: 'ถุงพลาสติกใช้เวลาย่อยสลาย 10-1,000 ปี' },
  { name: 'ใบไม้แห้ง', emoji: '🍂', bin: 'organic', fact: 'ใบไม้แห้งทำปุ๋ยหมักได้ดีเยี่ยม' },
  { name: 'กล่องโฟม', emoji: '📦', bin: 'general', fact: 'โฟมใช้เวลาย่อยสลายมากกว่า 500 ปี' },
  { name: 'ยาหมดอายุ', emoji: '💊', bin: 'hazardous', fact: 'ยาหมดอายุปนเปื้อนในน้ำส่งผลต่อสิ่งมีชีวิต' },
];

const bins = [
  { id: 'recycle', name: 'รีไซเคิล', emoji: '♻️', class: 'blue' },
  { id: 'organic', name: 'อินทรีย์', emoji: '🌱', class: 'green' },
  { id: 'general', name: 'ทั่วไป', emoji: '🗑️', class: 'yellow' },
  { id: 'hazardous', name: 'อันตราย', emoji: '☣️', class: 'red' },
];

let gameState = {
  items: [],
  current: 0,
  score: 0,
  answers: [],
  feedback: '',
  feedbackType: '',
  disabled: false
};

function shuffleArray(arr) {
  const a = [...arr];
  for (let i = a.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [a[i], a[j]] = [a[j], a[i]];
  }
  return a;
}

function initGame() {
  gameState = {
    items: shuffleArray(wasteItems).slice(0, 10),
    current: 0,
    score: 0,
    answers: [],
    feedback: '',
    feedbackType: '',
    disabled: false
  };
  renderGame();
}

function handleAnswer(binId) {
  if (gameState.disabled) return;
  gameState.disabled = true;
  
  const item = gameState.items[gameState.current];
  const correct = binId === item.bin;
  
  if (correct) {
    gameState.score++;
    gameState.feedback = `✅ ถูกต้อง! ${item.fact}`;
    gameState.feedbackType = 'correct';
  } else {
    const correctBin = bins.find(b => b.id === item.bin);
    gameState.feedback = `❌ ผิดนะ — ควรทิ้งในถัง "${correctBin.name}" ${item.fact}`;
    gameState.feedbackType = 'wrong';
  }
  
  gameState.answers.push(correct);
  
  // Highlight buttons
  renderGame();
  
  setTimeout(() => {
    gameState.current++;
    gameState.feedback = '';
    gameState.disabled = false;
    renderGame();
  }, 2200);
}

function renderGame() {
  const container = document.getElementById('gameContainer');
  
  if (gameState.items.length === 0) {
    initGame();
    return;
  }
  
  if (gameState.current >= gameState.items.length) {
    // Game over
    const pct = Math.round((gameState.score / gameState.items.length) * 100);
    let msg = '';
    if (pct >= 90) msg = '🏆 เก่งมาก! คุณเป็นนักอนุรักษ์ตัวจริง!';
    else if (pct >= 70) msg = '🌟 ดีมาก! ความรู้ดีเยี่ยม!';
    else if (pct >= 50) msg = '💪 พอใช้ได้! ลองฝึกเพิ่มนะ';
    else msg = '📚 มาเรียนรู้เพิ่มเติมเรื่องการคัดแยกขยะกัน!';
    
    container.innerHTML = `
      <div class="game-result">
        <h3>จบเกมแล้ว!</h3>
        <div class="big-score">${gameState.score}/${gameState.items.length}</div>
        <p>${msg}</p>
        <button class="btn btn-primary" onclick="initGame()">🔄 เล่นอีกครั้ง</button>
      </div>
    `;
    return;
  }
  
  const item = gameState.items[gameState.current];
  
  container.innerHTML = `
    <div class="game-score-bar">
      <span>ข้อ ${gameState.current + 1}/${gameState.items.length}</span>
      <span>คะแนน: <span class="score-value">${gameState.score}</span></span>
    </div>
    <div class="game-question">ขยะชิ้นนี้ ควรทิ้งถังไหน?</div>
    <div class="game-item">${item.emoji}</div>
    <div class="game-item-name">${item.name}</div>
    <div class="bin-options">
      ${bins.map(bin => {
        let extra = '';
        if (gameState.feedback) {
          if (bin.id === item.bin && gameState.feedbackType === 'correct') extra = ' correct';
          else if (bin.id === item.bin && gameState.feedbackType === 'wrong') extra = ' correct';
          else if (bin.id !== item.bin && gameState.feedbackType === 'wrong') extra = '';
        }
        return `<button class="bin-btn ${bin.class}${extra}" onclick="handleAnswer('${bin.id}')">
          <span class="bin-emoji">${bin.emoji}</span>
          ${bin.name}
        </button>`;
      }).join('')}
    </div>
    ${gameState.feedback ? `<div class="game-feedback ${gameState.feedbackType}">${gameState.feedback}</div>` : '<div class="game-feedback"></div>'}
    <div class="game-progress">
      ${gameState.items.map((_, i) => {
        let cls = '';
        if (i < gameState.answers.length) cls = gameState.answers[i] ? 'correct' : 'wrong';
        else if (i === gameState.current) cls = 'current';
        return `<div class="progress-dot ${cls}"></div>`;
      }).join('')}
    </div>
  `;
}

initGame();

// ===== PHOTOBOOTH =====
const frames = [
  {
    id: 'green-heart',
    name: '💚 Green Heart',
    bgColor: '#1a5c2a',
    borderWidth: 50,
    draw: function(ctx, w, h) {
      // Green gradient border
      const grd = ctx.createLinearGradient(0, 0, w, h);
      grd.addColorStop(0, '#0d3b1a');
      grd.addColorStop(0.5, '#2d8a4e');
      grd.addColorStop(1, '#0d3b1a');
      ctx.fillStyle = grd;
      ctx.fillRect(0, 0, w, h);
      
      // Inner photo area will be drawn by the main function
      
      // Top banner
      ctx.fillStyle = 'rgba(0,0,0,0.4)';
      ctx.fillRect(0, 0, w, 80);
      ctx.font = 'bold 32px Fredoka, sans-serif';
      ctx.fillStyle = '#a8e6a3';
      ctx.textAlign = 'center';
      ctx.fillText('NITIRAT GREEN HEART', w/2, 52);
      
      // Bottom banner
      ctx.fillStyle = 'rgba(0,0,0,0.4)';
      ctx.fillRect(0, h - 90, w, 90);
      ctx.font = 'bold 24px Fredoka, sans-serif';
      ctx.fillStyle = '#ffd700';
      ctx.textAlign = 'center';
      ctx.fillText('21 มีนาคม 2569', w/2, h - 52);
      ctx.font = '16px Prompt, sans-serif';
      ctx.fillStyle = '#a8e6a3';
      ctx.fillText('เขียวรักษ์โลก 💚', w/2, h - 24);
      
      // Corner leaves
      ctx.font = '42px serif';
      ctx.fillText('🍃', 40, 140);
      ctx.fillText('🌿', w - 40, 140);
      ctx.fillText('🌱', 40, h - 110);
      ctx.fillText('🍀', w - 40, h - 110);
    }
  },
  {
    id: 'eco-warrior',
    name: '🌍 Eco Warrior',
    bgColor: '#2d8a4e',
    borderWidth: 50,
    draw: function(ctx, w, h) {
      // Earth tones
      const grd = ctx.createLinearGradient(0, 0, 0, h);
      grd.addColorStop(0, '#1a472a');
      grd.addColorStop(1, '#2d5a2d');
      ctx.fillStyle = grd;
      ctx.fillRect(0, 0, w, h);
      
      // Diagonal stripes
      ctx.strokeStyle = 'rgba(168,230,163,0.15)';
      ctx.lineWidth = 20;
      for (let i = -h; i < w + h; i += 60) {
        ctx.beginPath();
        ctx.moveTo(i, 0);
        ctx.lineTo(i + h, h);
        ctx.stroke();
      }
      
      // Top
      ctx.fillStyle = 'rgba(0,0,0,0.5)';
      roundRect(ctx, 20, 16, w - 40, 60, 12);
      ctx.fill();
      ctx.font = 'bold 28px Fredoka, sans-serif';
      ctx.fillStyle = '#ffd700';
      ctx.textAlign = 'center';
      ctx.fillText('🌍 NITIRAT GREEN HEART 🌍', w/2, 54);
      
      // Bottom
      ctx.fillStyle = 'rgba(0,0,0,0.5)';
      roundRect(ctx, 20, h - 80, w - 40, 64, 12);
      ctx.fill();
      ctx.font = '20px Prompt, sans-serif';
      ctx.fillStyle = '#fff';
      ctx.fillText('Go Green • Save Energy • Reduce Waste', w/2, h - 42);
    }
  },
  {
    id: 'pastel-garden',
    name: '🌸 Pastel Garden',
    bgColor: '#d4f5d0',
    borderWidth: 50,
    draw: function(ctx, w, h) {
      // Pastel bg
      ctx.fillStyle = '#d4f5d0';
      ctx.fillRect(0, 0, w, h);
      
      // Polka dots
      ctx.fillStyle = 'rgba(76,175,80,0.15)';
      for (let x = 0; x < w; x += 40) {
        for (let y = 0; y < h; y += 40) {
          ctx.beginPath();
          ctx.arc(x + (y % 80 === 0 ? 0 : 20), y, 6, 0, Math.PI * 2);
          ctx.fill();
        }
      }
      
      // Top ribbon
      ctx.fillStyle = '#4caf50';
      ctx.fillRect(0, 0, w, 70);
      ctx.font = 'bold 26px Fredoka, sans-serif';
      ctx.fillStyle = '#fff';
      ctx.textAlign = 'center';
      ctx.fillText('🌿 NITIRAT Green Heart 🌿', w/2, 46);
      
      // Bottom
      ctx.fillStyle = '#4caf50';
      ctx.fillRect(0, h - 70, w, 70);
      ctx.font = 'bold 22px Prompt, sans-serif';
      ctx.fillStyle = '#fff';
      ctx.fillText('21 มีนาคม 2569 💚', w/2, h - 32);
    }
  },
  {
    id: 'nature-wild',
    name: '🌳 Nature Wild',
    bgColor: '#0d3b1a',
    borderWidth: 50,
    draw: function(ctx, w, h) {
      // Dark forest
      ctx.fillStyle = '#0d3b1a';
      ctx.fillRect(0, 0, w, h);
      
      // Vignette
      const vgrd = ctx.createRadialGradient(w/2, h/2, w*0.25, w/2, h/2, w*0.7);
      vgrd.addColorStop(0, 'rgba(0,0,0,0)');
      vgrd.addColorStop(1, 'rgba(0,0,0,0.4)');
      ctx.fillStyle = vgrd;
      ctx.fillRect(0, 0, w, h);
      
      // Top
      ctx.font = 'bold 34px Fredoka, sans-serif';
      ctx.fillStyle = '#4caf50';
      ctx.textAlign = 'center';
      ctx.fillText('NITIRAT', w/2, 50);
      ctx.font = 'bold 28px Fredoka, sans-serif';
      ctx.fillStyle = '#a8e6a3';
      ctx.fillText('GREEN HEART', w/2, 82);
      
      // Bottom
      ctx.font = 'bold 20px Prompt, sans-serif';
      ctx.fillStyle = '#ffd700';
      ctx.fillText('เขียวรักษ์โลก 🌱', w/2, h - 40);
      ctx.font = '16px Prompt, sans-serif';
      ctx.fillStyle = '#a8e6a3';
      ctx.fillText('21 มีนาคม 2569 • HR NITIRAT', w/2, h - 16);
    }
  }
];

function roundRect(ctx, x, y, w, h, r) {
  ctx.beginPath();
  ctx.moveTo(x + r, y);
  ctx.lineTo(x + w - r, y);
  ctx.quadraticCurveTo(x + w, y, x + w, y + r);
  ctx.lineTo(x + w, y + h - r);
  ctx.quadraticCurveTo(x + w, y + h, x + w - r, y + h);
  ctx.lineTo(x + r, y + h);
  ctx.quadraticCurveTo(x, y + h, x, y + h - r);
  ctx.lineTo(x, y + r);
  ctx.quadraticCurveTo(x, y, x + r, y);
  ctx.closePath();
}

let selectedFrame = 0;
let uploadedImage = null;

function initPhotobooth() {
  const selector = document.getElementById('frameSelector');
  selector.innerHTML = frames.map((f, i) => 
    `<div class="frame-option ${i === 0 ? 'active' : ''}" onclick="selectFrame(${i})" style="background:${f.bgColor};color:${f.bgColor === '#0d3b1a' || f.bgColor === '#2d8a4e' || f.bgColor === '#1a5c2a' ? '#fff' : '#1a5c2a'}">${f.name}</div>`
  ).join('');
  
  renderCanvas();
}

function selectFrame(idx) {
  selectedFrame = idx;
  document.querySelectorAll('.frame-option').forEach((el, i) => {
    el.classList.toggle('active', i === idx);
  });
  renderCanvas();
}

function renderCanvas() {
  const canvas = document.getElementById('photoCanvas');
  const ctx = canvas.getContext('2d');
  const w = canvas.width;
  const h = canvas.height;
  
  ctx.clearRect(0, 0, w, h);
  
  const frame = frames[selectedFrame];
  const bw = frame.borderWidth;
  
  // Draw frame bg first
  frame.draw(ctx, w, h);
  
  // Draw photo area
  if (uploadedImage) {
    // Calculate cover fit for the inner area
    const innerX = bw;
    const innerY = bw + 40;
    const innerW = w - bw * 2;
    const innerH = h - bw * 2 - 40;
    
    const imgRatio = uploadedImage.width / uploadedImage.height;
    const areaRatio = innerW / innerH;
    
    let sx, sy, sw, sh;
    if (imgRatio > areaRatio) {
      sh = uploadedImage.height;
      sw = sh * areaRatio;
      sx = (uploadedImage.width - sw) / 2;
      sy = 0;
    } else {
      sw = uploadedImage.width;
      sh = sw / areaRatio;
      sx = 0;
      sy = (uploadedImage.height - sh) / 2;
    }
    
    ctx.save();
    roundRect(ctx, innerX, innerY, innerW, innerH, 8);
    ctx.clip();
    ctx.drawImage(uploadedImage, sx, sy, sw, sh, innerX, innerY, innerW, innerH);
    ctx.restore();
  } else {
    // Placeholder
    const innerX = bw;
    const innerY = bw + 40;
    const innerW = w - bw * 2;
    const innerH = h - bw * 2 - 40;
    
    ctx.fillStyle = 'rgba(255,255,255,0.1)';
    roundRect(ctx, innerX, innerY, innerW, innerH, 8);
    ctx.fill();
    
    ctx.font = '48px serif';
    ctx.textAlign = 'center';
    ctx.fillText('📷', w/2, h/2 - 10);
    ctx.font = '18px Prompt, sans-serif';
    ctx.fillStyle = 'rgba(255,255,255,0.6)';
    ctx.fillText('อัปโหลดรูปภาพของคุณ', w/2, h/2 + 30);
  }
  
  // Re-draw frame overlays on top
  frame.draw(ctx, w, h);
}

document.getElementById('photoUpload').addEventListener('change', function(e) {
  const file = e.target.files[0];
  if (!file) return;
  
  const img = new Image();
  img.onload = function() {
    uploadedImage = img;
    renderCanvas();
  };
  img.src = URL.createObjectURL(file);
});

function savePhoto() {
  const canvas = document.getElementById('photoCanvas');
  const link = document.createElement('a');
  link.download = 'NITIRAT-GreenHeart-Photo.png';
  link.href = canvas.toDataURL('image/png');
  link.click();
}

initPhotobooth();

// ===== SMOOTH NAV =====
document.querySelectorAll('a[href^="#"]').forEach(anchor => {
  anchor.addEventListener('click', function(e) {
    e.preventDefault();
    const target = document.querySelector(this.getAttribute('href'));
    if (target) {
      target.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }
  });
});
